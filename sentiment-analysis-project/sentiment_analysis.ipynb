    "# Calculate helpfulness rate from the list [helpful/0, helpful/1]\n",
    "def calculate_helpful_rate(helpful_list):\n",
    "    if helpful_list[0] == 0:\n",
    "        return 0\n",
    "    else:\n",
    "        return round(helpful_list[0] / helpful_list[1], 2)\n",
    "\n",
    "df['helpful_rate'] = df['helpful'].apply(calculate_helpful_rate)\n",
