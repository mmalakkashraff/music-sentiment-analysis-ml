    "\n",
    "def perform_stemming(text):\n",
    "    \"\"\"\n",
    "    Apply stemming to a given text using PorterStemmer.\n",
    "    \"\"\"\n",
    "    words = text.split()\n",
    "    stemmed_words = [ps.stem(word) for word in words]\n",
    "    return ' '.join(stemmed_words)"
   ]
