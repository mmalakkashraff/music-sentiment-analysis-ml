# Calculate helpfulness rate from the list [helpful/0, helpful/1]
def calculate_helpful_rate(helpful_list):
    if helpful_list[0] == 0:
        return 0
    else:
        return round(helpful_list[0] / helpful_list[1], 2)

df['helpful_rate'] = df['helpful'].apply(calculate_helpful_rate)

